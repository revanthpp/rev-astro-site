---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCertifications, getProfile } from '../lib/siteContent';

const interests = [
	'Applied AI in the enterprise',
	'Agentic workflows and AI assistants',
	'AI productization',
	'Evaluation and observability',
	'AI operating models',
	'Infrastructure and reliability for AI systems',
];
const profile = getProfile();
const certifications = getCertifications().filter((certification) => certification.featured);
---

<SiteLayout
	title="About | Revanth Pattipati"
	description="About Revanth Pattipati — applied AI leader with infrastructure roots."
>
	<section class="about-page section-shell">
		<header>
			<p class="kicker">About</p>
			<h1>About</h1>
		</header>

		<div class="about-grid">
			<div class="prose">
				<p>{profile.shortBio}</p>
				<p>{profile.longBio}</p>
				<p>
					I believe the next phase of AI will not be won by the teams with the most
					prototypes. It will be won by the teams that build the nervous system around those
					prototypes: evaluation, governance, orchestration, feedback loops, ownership, and
					operational discipline.
				</p>
				<p>{profile.personalInterests}</p>
			</div>
			<aside>
				<img class="about-photo" src={profile.images.professional.src} alt={profile.images.professional.alt} />
				<h2>Current interests</h2>
				<div class="interest-list">
					{interests.map((interest) => <span>{interest}</span>)}
				</div>
				{certifications.length > 0 && (
					<div class="certifications">
						<h2>Featured certifications</h2>
						{certifications.map((certification) => (
							<p>
								<strong>{certification.name}</strong>
								<span>{certification.issuer} / {certification.date}</span>
							</p>
						))}
					</div>
				)}
			</aside>
		</div>
	</section>
</SiteLayout>

<style>
	.about-page {
		padding: 5rem 0 7rem;
	}

	header {
		max-width: 1040px;
		margin-bottom: 3rem;
	}

	header h1 {
		margin-top: 0.7rem;
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 360px;
		gap: 4rem;
		align-items: start;
	}

	.prose {
		max-width: 760px;
		font-size: 1.12rem;
	}

	aside {
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.58);
		padding: 1.25rem;
	}

	aside h2 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
	}

	.about-photo {
		width: 100%;
		aspect-ratio: 4 / 5;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		margin-bottom: 1.25rem;
		object-fit: cover;
		object-position: center 34%;
	}

	.interest-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.interest-list span {
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.76rem;
		padding: 0.3rem 0.55rem;
	}

	.certifications {
		border-top: 1px solid var(--line);
		margin-top: 1.4rem;
		padding-top: 1.4rem;
	}

	.certifications p {
		display: grid;
		gap: 0.15rem;
		margin-top: 0.8rem;
	}

	.certifications strong {
		color: var(--ink);
	}

	.certifications span {
		color: var(--muted);
		font-size: 0.9rem;
	}

	@media (max-width: 820px) {
		.about-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
