---
import SystemFlow from '../components/SystemFlow.astro';
import { SOCIAL_LINKS } from '../consts';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCertifications, getProfile } from '../lib/siteContent';

const profile = getProfile();
const certifications = getCertifications().filter((certification) => certification.featured);
const careerFlow = [
	{ label: 'IT engineering', detail: 'Learned how systems fail.' },
	{ label: 'Analytics and data', detail: 'Learned to find the signal.' },
	{ label: 'Cloud infrastructure', detail: 'Learned what scale costs.' },
	{ label: 'Applied AI', detail: 'Now putting judgment into the loop.' },
];
---

<SiteLayout
	title="About and Contact | Revanth Pattipati"
	description="About Revanth Pattipati, an applied AI leader in Chicago with infrastructure roots, plus certifications and contact links."
>
	<section class="about-hero section-shell">
		<div>
			<p class="kicker">About</p>
			<h1>Infrastructure roots. Applied AI focus.</h1>
			<p class="intro">
				I turn AI ideas into systems that can survive permissions, cost, latency, governance,
				and the deeply inconvenient existence of production.
			</p>
			<p class="location">{profile.location}</p>
		</div>
		<img src={profile.images.professional.src} alt={profile.images.professional.alt} />
	</section>

	<section class="career section-shell" aria-labelledby="career-heading">
		<header>
			<p class="kicker">The path here</p>
			<h2 id="career-heading">A useful sequence of hard lessons.</h2>
		</header>
		<SystemFlow
			steps={careerFlow}
			label="Career path from IT engineering through analytics and cloud infrastructure to applied AI"
		/>
	</section>

	<section class="about-copy section-shell">
		<div>
			<p>{profile.shortBio}</p>
			<p>
				My work sits around the model: orchestration, evaluation, security, observability, and
				the operating decisions that turn a promising demo into something people can trust.
			</p>
		</div>
		<p>
			Outside work, I am usually training for something or finding outdoor hobbies that make risk
			management feel less theoretical. I like systems with guardrails and hobbies that
			occasionally test them.
		</p>
	</section>

	<section class="credentials section-shell" aria-labelledby="credentials-heading">
		<header>
			<p class="kicker">Credentials</p>
			<h2 id="credentials-heading">The full names, for once.</h2>
		</header>
		<div class="credential-list">
			{certifications.map((certification, index) => (
				<article>
					<span>{String(index + 1).padStart(2, '0')}</span>
					<div>
						<h3>{certification.name}</h3>
						<p>{certification.issuer}</p>
					</div>
					<div class="credential-meta">
						{certification.date && <span>{certification.date}</span>}
						{certification.credentialId && <span>Credential {certification.credentialId}</span>}
					</div>
				</article>
			))}
		</div>
	</section>

	<section class="contact section-shell" id="contact" aria-labelledby="contact-heading">
		<div>
			<p class="kicker">Contact</p>
			<h2 id="contact-heading">Good questions travel well.</h2>
			<p>For thoughtful conversations about AI systems, enterprise architecture, and the part after the demo.</p>
		</div>
		<nav aria-label="Contact Revanth Pattipati">
			<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noreferrer">
				<span>LinkedIn</span>
				<strong>Connect professionally →</strong>
			</a>
			<a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">
				<span>GitHub</span>
				<strong>Inspect the work →</strong>
			</a>
			<a href={SOCIAL_LINKS.email}>
				<span>Email</span>
				<strong>Start a conversation →</strong>
			</a>
		</nav>
	</section>
</SiteLayout>

<style>
	:global(body.site-body) {
		background: #f6f5f1;
	}

	.about-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.46fr);
		gap: clamp(3rem, 8vw, 8rem);
		align-items: center;
		padding: clamp(5rem, 10vw, 8rem) 0;
	}

	.about-hero > div {
		display: grid;
		gap: 1rem;
	}

	.about-hero h1 {
		max-width: 900px;
		font-size: clamp(3.6rem, 8vw, 7rem);
		letter-spacing: -0.06em;
	}

	.intro {
		max-width: 690px;
		color: var(--graphite);
		font-size: clamp(1.08rem, 2vw, 1.3rem);
	}

	.location {
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.09em;
		text-transform: uppercase;
	}

	.about-hero img {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 5;
		border: 1px solid var(--line);
		border-radius: 18px;
		box-shadow: var(--shadow);
		object-fit: cover;
		object-position: center 32%;
	}

	.career,
	.credentials,
	.contact {
		border-top: 1px solid var(--line);
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.career {
		display: grid;
		grid-template-columns: minmax(220px, 0.38fr) minmax(0, 1fr);
		gap: clamp(2rem, 6vw, 6rem);
		align-items: center;
	}

	.career header,
	.credentials header,
	.contact > div {
		display: grid;
		gap: 0.7rem;
	}

	.career h2,
	.credentials h2,
	.contact h2 {
		font-size: clamp(2.4rem, 5vw, 4.8rem);
		letter-spacing: -0.045em;
	}

	.about-copy {
		display: grid;
		grid-template-columns: 1fr 0.72fr;
		gap: clamp(3rem, 8vw, 8rem);
		border-top: 1px solid var(--ink);
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.about-copy > div {
		display: grid;
		gap: 1.2rem;
	}

	.about-copy p {
		font-size: clamp(1.05rem, 1.8vw, 1.22rem);
		line-height: 1.75;
	}

	.credentials header {
		max-width: 720px;
		margin-bottom: 2.5rem;
	}

	.credential-list {
		border-top: 1px solid var(--ink);
	}

	.credential-list article {
		display: grid;
		grid-template-columns: 70px minmax(0, 1fr) minmax(210px, 0.35fr);
		gap: 1.5rem;
		align-items: start;
		border-bottom: 1px solid var(--line);
		padding: 1.8rem 0;
	}

	.credential-list article > span,
	.credential-meta span {
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.66rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.credential-list h3 {
		max-width: 720px;
		font-size: clamp(1.3rem, 2.6vw, 2.1rem);
		line-height: 1.18;
	}

	.credential-list p {
		margin-top: 0.4rem;
	}

	.credential-meta {
		display: grid;
		gap: 0.4rem;
	}

	.contact {
		display: grid;
		grid-template-columns: minmax(0, 0.75fr) minmax(320px, 0.55fr);
		gap: clamp(3rem, 8vw, 8rem);
		align-items: start;
	}

	.contact > div > p:not(.kicker) {
		max-width: 620px;
		margin-top: 0.5rem;
	}

	.contact nav {
		display: grid;
		border-top: 1px solid var(--ink);
	}

	.contact nav a {
		display: grid;
		gap: 0.25rem;
		border-bottom: 1px solid var(--line);
		color: inherit;
		padding: 1.15rem 0;
		text-decoration: none;
	}

	.contact nav a:hover strong {
		color: var(--accent);
	}

	.contact nav span {
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.66rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.contact nav strong {
		transition: color 160ms ease;
	}

	@media (max-width: 820px) {
		.about-hero,
		.career,
		.about-copy,
		.contact {
			grid-template-columns: 1fr;
		}

		.about-hero img {
			max-width: 430px;
		}

		.credential-list article {
			grid-template-columns: 1fr;
			gap: 0.8rem;
		}

		.credential-list article > span {
			display: none;
		}
	}
</style>
