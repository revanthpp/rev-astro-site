---
import { getCollection } from 'astro:content';
import SystemFlow from '../../components/SystemFlow.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const projects = (await getCollection('projects'))
	.filter((project) => !project.data.draft)
	.sort((a, b) => {
		if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
		return a.data.priority - b.data.priority;
	});
const buildFlow = [
	{ label: 'Problem', detail: 'Name the operational risk.' },
	{ label: 'Boundaries', detail: 'Make policy and constraints explicit.' },
	{ label: 'Build', detail: 'Create the smallest useful system.' },
	{ label: 'Evaluate', detail: 'Keep evidence, not vibes.' },
];
const projectFlows: Record<string, Array<{ label: string }>> = {
	'agentops-reference-architecture': [
		{ label: 'Scenario' },
		{ label: 'Route' },
		{ label: 'Execute' },
		{ label: 'Evaluate' },
	],
	'cost-aware-model-router': [
		{ label: 'Task' },
		{ label: 'Policy' },
		{ label: 'Browser' },
		{ label: 'Trace' },
	],
	evalkit: [
		{ label: 'Cases' },
		{ label: 'Run' },
		{ label: 'Score' },
		{ label: 'Review' },
	],
	'llm-observability-dashboard': [
		{ label: 'Failure' },
		{ label: 'Fixture' },
		{ label: 'Trace' },
		{ label: 'Mitigate' },
	],
	'secure-tool-calling-sandbox': [
		{ label: 'Request' },
		{ label: 'Policy' },
		{ label: 'Approve' },
		{ label: 'Audit' },
	],
	'mcp-notes-server': [
		{ label: 'Ask' },
		{ label: 'Discover' },
		{ label: 'Validate' },
		{ label: 'Notes' },
	],
	'a2a-agent-network': [
		{ label: 'Request' },
		{ label: 'Discover' },
		{ label: 'Delegate' },
		{ label: 'Return' },
	],
};
---

<SiteLayout
	title="Projects | Revanth Pattipati"
	description="Working AI systems, architecture decisions, tradeoffs, GitHub repositories, and detailed writeups by Revanth Pattipati."
>
	<section class="page-hero section-shell">
		<p class="kicker">Projects</p>
		<h1>Systems you can inspect.</h1>
		<p>Working builds, reference architectures, and the tradeoffs hiding behind the tidy diagram.</p>
	</section>

	<section class="method section-shell" aria-labelledby="method-heading">
		<div>
			<p class="kicker">Build loop</p>
			<h2 id="method-heading">Less magic. More evidence.</h2>
		</div>
		<SystemFlow
			steps={buildFlow}
			label="Project method from the problem through boundaries and building to evaluation"
		/>
	</section>

	<section class="project-list section-shell" aria-label="AI projects">
		{projects.map((project, index) => (
			<a class="project-card" href={`/systems/${project.id}/`}>
				<div class="project-number">{String(index + 1).padStart(2, '0')}</div>
				<div class="project-copy">
					<div class="project-meta">
						<span>{project.data.status}</span>
						<span>{project.data.category}</span>
						{project.data.series && <span class="series-tag">{project.data.series}</span>}
					</div>
					<h2>{project.data.title}</h2>
					<p>{project.data.description}</p>
					<ul>
						{project.data.technologies.slice(0, 4).map((tech) => <li>{tech}</li>)}
					</ul>
				</div>
				<div class="project-flow">
					<SystemFlow
						steps={projectFlows[project.id] ?? buildFlow}
						label={`${project.data.title} system flow`}
						compact
					/>
					<strong>Open project →</strong>
				</div>
			</a>
		))}
	</section>
</SiteLayout>

<style>
	:global(body.site-body) {
		background: #f6f5f1;
	}

	.page-hero {
		padding: clamp(5rem, 10vw, 8rem) 0 clamp(3rem, 6vw, 5rem);
	}

	.page-hero h1 {
		max-width: 1040px;
		margin: 0.7rem 0 1.2rem;
		font-size: clamp(3.8rem, 9vw, 8rem);
		letter-spacing: -0.06em;
	}

	.page-hero p:not(.kicker) {
		max-width: 710px;
		color: var(--graphite);
		font-size: clamp(1.05rem, 2vw, 1.25rem);
	}

	.method {
		display: grid;
		grid-template-columns: minmax(220px, 0.38fr) minmax(0, 1fr);
		gap: clamp(2rem, 6vw, 6rem);
		align-items: center;
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: clamp(3rem, 7vw, 5rem) 0;
	}

	.method > div {
		display: grid;
		gap: 0.7rem;
	}

	.method h2 {
		font-size: clamp(2rem, 4vw, 3.6rem);
		letter-spacing: -0.04em;
	}

	.project-list {
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.project-card {
		display: grid;
		grid-template-columns: 70px minmax(0, 1fr) minmax(320px, 0.8fr);
		gap: clamp(1rem, 4vw, 3.5rem);
		align-items: center;
		border-bottom: 1px solid var(--line);
		color: inherit;
		padding: clamp(2rem, 5vw, 4rem) 0;
		text-decoration: none;
	}

	.project-card:first-child {
		border-top: 1px solid var(--ink);
	}

	.project-card:hover h2,
	.project-card:hover .project-flow > strong {
		color: var(--accent);
	}

	.project-number {
		align-self: start;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
	}

	.project-copy {
		display: grid;
		gap: 1rem;
	}

	.project-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem 1rem;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.65rem;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.project-copy h2 {
		font-size: clamp(2rem, 4.5vw, 4rem);
		letter-spacing: -0.045em;
		transition: color 160ms ease;
	}

	.series-tag {
		color: var(--accent);
		font-weight: 700;
	}

	.project-copy p {
		max-width: 620px;
	}

	.project-copy ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.project-copy li {
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.66rem;
		padding: 0.25rem 0.5rem;
	}

	.project-flow {
		display: grid;
		gap: 0.85rem;
	}

	.project-flow > strong {
		justify-self: end;
		font-size: 0.82rem;
		transition: color 160ms ease;
	}

	@media (max-width: 900px) {
		.method,
		.project-card {
			grid-template-columns: 1fr;
		}

		.project-number {
			display: none;
		}

		.project-flow > strong {
			justify-self: start;
		}
	}
</style>
