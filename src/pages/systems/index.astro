---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

const projects = (await getCollection('projects')).filter((project) => !project.data.draft);
---

<SiteLayout
	title="Systems Work | Revanth Pattipati"
	description="Production-style AI systems work by Revanth Pattipati, including evaluation frameworks, agent operations architecture, cost-aware routing, secure tool-calling, and LLM observability."
>
	<section class="page-hero section-shell">
		<p class="kicker">Systems Work</p>
		<h1>Technical explorations designed around real production constraints.</h1>
		<p>
			Reference architectures and project concepts for evaluation, orchestration, secure
			execution, model routing, and observability.
		</p>
	</section>

	<section class="project-grid section-shell">
		{projects.map((project) => (
			<a class="project-card" href={`/systems/${project.id}/`}>
				<div class="diagram" aria-hidden="true">
					<span></span><span></span><span></span><span></span>
				</div>
				<div class="project-body">
					<span class="tag">{project.data.status}</span>
					<h2>{project.data.title}</h2>
					<p>{project.data.description}</p>
					<ul>
						{project.data.technologies.slice(0, 4).map((tech) => <li>{tech}</li>)}
					</ul>
				</div>
			</a>
		))}
	</section>
</SiteLayout>

<style>
	.page-hero {
		padding: 5rem 0 3rem;
	}

	.page-hero h1 {
		max-width: 1040px;
		margin: 0.7rem 0 1.2rem;
	}

	.page-hero p:not(.kicker) {
		max-width: 760px;
		font-size: 1.18rem;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		padding-bottom: 6rem;
	}

	.project-card {
		display: grid;
		grid-template-columns: 0.8fr 1fr;
		min-height: 340px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.58);
		color: inherit;
		overflow: hidden;
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease,
			background 160ms ease;
	}

	.project-card:hover {
		background: var(--surface);
		box-shadow: var(--shadow);
		transform: translateY(-2px);
	}

	.diagram {
		position: relative;
		min-height: 100%;
		border-right: 1px solid var(--line);
		background-image:
			linear-gradient(rgba(17, 19, 24, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(17, 19, 24, 0.045) 1px, transparent 1px);
		background-size: 34px 34px;
	}

	.diagram span {
		position: absolute;
		width: 44%;
		height: 42px;
		border: 1px solid rgba(21, 93, 252, 0.22);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.8);
	}

	.diagram span:nth-child(1) {
		left: 16%;
		top: 18%;
	}

	.diagram span:nth-child(2) {
		right: 12%;
		top: 39%;
	}

	.diagram span:nth-child(3) {
		left: 18%;
		bottom: 22%;
	}

	.diagram span:nth-child(4) {
		right: 18%;
		bottom: 9%;
		width: 10px;
		height: 10px;
		border-radius: 999px;
		background: var(--accent);
		box-shadow: 0 0 0 12px rgba(21, 93, 252, 0.1);
	}

	.project-body {
		display: grid;
		align-content: space-between;
		gap: 1.2rem;
		padding: 1.25rem;
	}

	.project-body h2 {
		font-size: 1.7rem;
	}

	ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	li {
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.72rem;
		padding: 0.25rem 0.45rem;
	}

	@media (max-width: 980px) {
		.project-grid,
		.project-card {
			grid-template-columns: 1fr;
		}

		.diagram {
			min-height: 220px;
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}
	}
</style>
