---
import { getCollection, render } from 'astro:content';
import SystemFlow from '../../components/SystemFlow.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

export async function getStaticPaths() {
	const projects = (await getCollection('projects')).filter((project) => !project.data.draft);
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projectFlows: Record<string, Array<{ label: string; detail: string }>> = {
	'agentops-reference-architecture': [
		{ label: 'Scenario', detail: 'Choose the workflow and constraints.' },
		{ label: 'Route', detail: 'Select a path and model.' },
		{ label: 'Execute', detail: 'Run tools with guardrails.' },
		{ label: 'Evaluate', detail: 'Compare cost, traces, and reliability.' },
	],
	'cost-aware-model-router': [
		{ label: 'Task', detail: 'Declare the intended outcome.' },
		{ label: 'Policy', detail: 'Check boundaries and approvals.' },
		{ label: 'Browser', detail: 'Execute the allowed interaction.' },
		{ label: 'Trace', detail: 'Capture evidence for review.' },
	],
	evalkit: [
		{ label: 'Cases', detail: 'Version prompts and scenarios.' },
		{ label: 'Run', detail: 'Exercise the workflow.' },
		{ label: 'Score', detail: 'Classify quality and failures.' },
		{ label: 'Review', detail: 'Make release decisions with evidence.' },
	],
	'llm-observability-dashboard': [
		{ label: 'Failure', detail: 'Name the behavior to reproduce.' },
		{ label: 'Fixture', detail: 'Create a deterministic case.' },
		{ label: 'Trace', detail: 'Inspect where the system drifted.' },
		{ label: 'Mitigate', detail: 'Document the architectural fix.' },
	],
	'secure-tool-calling-sandbox': [
		{ label: 'Request', detail: 'Receive a typed tool call.' },
		{ label: 'Policy', detail: 'Validate identity and scope.' },
		{ label: 'Approve', detail: 'Escalate risky actions to a human.' },
		{ label: 'Audit', detail: 'Record the decision and result.' },
	],
};
const architectureFlow = projectFlows[project.id] ?? [
	{ label: 'Input', detail: 'Receive a bounded task.' },
	{ label: 'Policy', detail: 'Apply system constraints.' },
	{ label: 'Execute', detail: 'Run the workflow.' },
	{ label: 'Trace', detail: 'Capture evidence.' },
];
---

<SiteLayout
	title={`${project.data.title} | Projects | Revanth Pattipati`}
	description={project.data.description}
>
	<article class="project-detail section-shell">
		<header class="project-header">
			<a class="back-link" href="/systems">Projects</a>
			<span class="tag">{project.data.status}</span>
			<h1>{project.data.title}</h1>
			<p>{project.data.description}</p>
		</header>

		<section class="architecture-panel" aria-labelledby="architecture-heading">
			<div>
				<p class="kicker">System flow</p>
				<h2 id="architecture-heading">How the pieces move.</h2>
			</div>
			<SystemFlow
				steps={architectureFlow}
				label={`${project.data.title} architecture flow`}
			/>
		</section>

		<div class="detail-grid">
			<section>
				<h2>Problem Statement</h2>
				<p>{project.data.problem}</p>
			</section>
			<section>
				<h2>Architecture Summary</h2>
				<p>{project.data.architecture}</p>
			</section>
			<section>
				<h2>Key Design Tradeoffs</h2>
				<ul>
					{project.data.tradeoffs.map((tradeoff) => <li>{tradeoff}</li>)}
				</ul>
			</section>
			<section>
				<h2>Technologies</h2>
				<div class="tech-list">
					{project.data.technologies.map((tech) => <span>{tech}</span>)}
				</div>
			</section>
		</div>

		<div class="prose">
			<Content />
		</div>

		<div class="button-row">
			{project.data.githubUrl && (
				<a class="button" href={project.data.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
			)}
			{project.data.writeupUrl && <a class="button secondary" href={project.data.writeupUrl}>Read write-up</a>}
		</div>
	</article>
</SiteLayout>

<style>
	.project-detail {
		padding: 5rem 0 7rem;
	}

	.project-header {
		display: grid;
		max-width: 980px;
		gap: 1rem;
		margin-bottom: 3rem;
	}

	.project-header h1 {
		font-size: clamp(3rem, 7vw, 6rem);
	}

	.project-header p {
		color: var(--graphite);
		font-size: 1.2rem;
		line-height: 1.55;
	}

	.back-link {
		width: fit-content;
		color: var(--muted);
		font-weight: 700;
		text-decoration: none;
	}

	.architecture-panel {
		display: grid;
		grid-template-columns: minmax(220px, 0.35fr) minmax(0, 1fr);
		gap: clamp(2rem, 6vw, 6rem);
		align-items: center;
		border-top: 1px solid var(--ink);
		border-bottom: 1px solid var(--line);
		margin-bottom: 3rem;
		padding: clamp(2.5rem, 6vw, 4.5rem) 0;
	}

	.architecture-panel > div {
		display: grid;
		gap: 0.7rem;
	}

	.architecture-panel h2 {
		font-size: clamp(2rem, 4vw, 3.5rem);
		letter-spacing: -0.04em;
	}

	.detail-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin-bottom: 3rem;
	}

	.detail-grid section {
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.58);
		padding: 1.25rem;
	}

	.detail-grid h2 {
		font-size: 1.25rem;
		margin-bottom: 0.8rem;
	}

	.detail-grid ul {
		color: var(--muted);
		margin: 0;
		padding-left: 1.1rem;
	}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tech-list span {
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.78rem;
		padding: 0.3rem 0.55rem;
	}

	.prose {
		max-width: 760px;
		margin-bottom: 2rem;
	}

	@media (max-width: 760px) {
		.detail-grid,
		.architecture-panel {
			grid-template-columns: 1fr;
		}
	}
</style>
