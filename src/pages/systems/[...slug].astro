---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

export async function getStaticPaths() {
	const projects = (await getCollection('projects')).filter((project) => !project.data.draft);
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<SiteLayout
	title={`${project.data.title} | Systems Work | Revanth Pattipati`}
	description={project.data.description}
>
	<article class="project-detail section-shell">
		<header class="project-header">
			<a class="back-link" href="/systems">Systems Work</a>
			<span class="tag">{project.data.status}</span>
			<h1>{project.data.title}</h1>
			<p>{project.data.description}</p>
		</header>

		<section class="architecture-panel" aria-label="Architecture diagram placeholder">
			<div class="arch-node main">Workflow</div>
			<div class="arch-node">Policy</div>
			<div class="arch-node">Tools</div>
			<div class="arch-node">Trace</div>
			<div class="arch-line"></div>
		</section>

		<div class="detail-grid">
			<section>
				<h2>Problem Statement</h2>
				<p>{project.data.problem}</p>
			</section>
			<section>
				<h2>Architecture Summary</h2>
				<p>{project.data.architecture}</p>
			</section>
			<section>
				<h2>Key Design Tradeoffs</h2>
				<ul>
					{project.data.tradeoffs.map((tradeoff) => <li>{tradeoff}</li>)}
				</ul>
			</section>
			<section>
				<h2>Technologies</h2>
				<div class="tech-list">
					{project.data.technologies.map((tech) => <span>{tech}</span>)}
				</div>
			</section>
		</div>

		<div class="prose">
			<Content />
		</div>

		<div class="button-row">
			{project.data.githubUrl && (
				<a class="button" href={project.data.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
			)}
			{project.data.writeupUrl && <a class="button secondary" href={project.data.writeupUrl}>Read write-up</a>}
		</div>
	</article>
</SiteLayout>

<style>
	.project-detail {
		padding: 5rem 0 7rem;
	}

	.project-header {
		display: grid;
		max-width: 980px;
		gap: 1rem;
		margin-bottom: 3rem;
	}

	.project-header h1 {
		font-size: clamp(3rem, 7vw, 6rem);
	}

	.project-header p {
		color: var(--graphite);
		font-size: 1.2rem;
		line-height: 1.55;
	}

	.back-link {
		width: fit-content;
		color: var(--muted);
		font-weight: 700;
		text-decoration: none;
	}

	.architecture-panel {
		position: relative;
		min-height: 420px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background:
			linear-gradient(120deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.48)),
			linear-gradient(rgba(17, 19, 24, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(17, 19, 24, 0.045) 1px, transparent 1px);
		background-size: auto, 42px 42px, 42px 42px;
		box-shadow: var(--shadow);
		margin-bottom: 3rem;
		overflow: hidden;
	}

	.arch-node {
		position: absolute;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.86);
		font-family: var(--mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		padding: 0.9rem 1.1rem;
		text-transform: uppercase;
	}

	.arch-node.main {
		left: 42%;
		top: 42%;
		border-color: rgba(21, 93, 252, 0.34);
		color: var(--accent);
	}

	.arch-node:nth-child(2) {
		left: 16%;
		top: 22%;
	}

	.arch-node:nth-child(3) {
		right: 18%;
		top: 24%;
	}

	.arch-node:nth-child(4) {
		left: 24%;
		bottom: 18%;
	}

	.arch-line {
		position: absolute;
		inset: 18% 20%;
		border: 1px solid rgba(21, 93, 252, 0.22);
		border-radius: 50%;
		transform: rotate(-12deg);
	}

	.detail-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin-bottom: 3rem;
	}

	.detail-grid section {
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.58);
		padding: 1.25rem;
	}

	.detail-grid h2 {
		font-size: 1.25rem;
		margin-bottom: 0.8rem;
	}

	.detail-grid ul {
		color: var(--muted);
		margin: 0;
		padding-left: 1.1rem;
	}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tech-list span {
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.78rem;
		padding: 0.3rem 0.55rem;
	}

	.prose {
		max-width: 760px;
		margin-bottom: 2rem;
	}

	@media (max-width: 760px) {
		.detail-grid {
			grid-template-columns: 1fr;
		}

		.architecture-panel {
			min-height: 340px;
		}

		.arch-node {
			font-size: 0.65rem;
			padding: 0.65rem 0.75rem;
		}
	}
</style>
