---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SOCIAL_LINKS } from '../consts';
import { getCertifications, getHomepage, getProfile } from '../lib/siteContent';

const profile = getProfile();
const homepage = getHomepage();
const writing = (await getCollection('writing'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredWriting = homepage.featuredWriting
	.map((id) => writing.find((post) => post.id === id))
	.filter(Boolean);
const allNotes = (await getCollection('notes'))
	.filter((note) => !note.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredNotes = homepage.featuredFieldNotes
	.map((id) => allNotes.find((note) => note.id === id))
	.filter(Boolean);
const currentThinking = featuredWriting.length > 0 ? featuredWriting : featuredNotes.slice(0, 3);
const currentThinkingCards = currentThinking.map((entry) => ({
	href: featuredWriting.length > 0 ? `/writing/${entry.id}/` : '/notes/',
	category: entry.data.category,
	meta: 'readingTime' in entry.data ? entry.data.readingTime : 'Field note',
	title: entry.data.title,
	description:
		'description' in entry.data
			? entry.data.description
			: 'A short note on the practical realities of applied AI.',
}));
const certifications = getCertifications().filter((certification) => certification.featured);
---

<SiteLayout
	title="Revanth Pattipati | AI Infrastructure & Agentic Systems Architect"
	description="Revanth Pattipati designs production-grade AI systems for enterprise scale, spanning agentic systems, LLM infrastructure, evaluation, observability, and secure AI workflows."
>
	<section class="hero section-shell">
		<div class="hero-copy">
			<p class="kicker">{profile.heroEyebrow}</p>
			<h1>{profile.heroHeadline}</h1>
			<p class="hero-subhead">{profile.heroSubheadline}</p>
			<p class="hero-support">{profile.heroSupportingLine}</p>
			<div class="button-row">
				<a class="button" href="/writing">{homepage.primaryCta}</a>
				<a class="button secondary" href={SOCIAL_LINKS.linkedin} target="_blank" rel="noreferrer"
					>{homepage.secondaryCta}</a
				>
			</div>
		</div>
		<div class="hero-visual" aria-label="Abstract architecture diagram">
			<div class="diagram-shell">
				<img class="hero-photo" src={profile.images.professional.src} alt={profile.images.professional.alt} />
				<div class="trace trace-a"></div>
				<div class="trace trace-b"></div>
				<div class="contour contour-a"></div>
				<div class="contour contour-b"></div>
				<div class="node node-primary">After demo</div>
				<div class="node node-evaluate">Evaluate</div>
				<div class="node node-adopt">Adopt</div>
				<div class="node node-operate">Operate</div>
				<div class="node node-govern">Govern</div>
				<div class="signal"></div>
			</div>
		</div>
	</section>

	<section class="credibility section-shell" aria-label="Core focus">
		{homepage.credibility.map((item) => <span>{item}</span>)}
	</section>

	<section class="about-preview section-shell" id="about-preview">
		<p class="kicker">{homepage.intro.eyebrow}</p>
		<div>
			<h2>{homepage.intro.headline}</h2>
			<p>{homepage.intro.body}</p>
		</div>
	</section>

	<section class="focus-section section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">{homepage.focusEyebrow}</p>
				<h2>{homepage.focusHeadline}</h2>
			</div>
			<p>{homepage.focusDescription}</p>
		</div>
		<div class="focus-grid">
			{homepage.focusAreas.map((area) => (
				<article class="focus-card">
					<h3>{area.title}</h3>
					<p>{area.description}</p>
				</article>
			))}
		</div>
	</section>

	<section class="writing-preview section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">{homepage.currentThinking.eyebrow}</p>
				<h2>{homepage.currentThinking.headline}</h2>
			</div>
			<a class="text-link" href="/writing">View all writing</a>
		</div>
		{featuredWriting.length === 0 && <p class="section-note">{homepage.currentThinking.fallback}</p>}
		<div class="writing-grid">
			{currentThinkingCards.map((entry) => (
				<a class="writing-card" href={entry.href}>
					<div class="card-topline">
						<span class="tag">{entry.category}</span>
						<span class="meta">{entry.meta}</span>
					</div>
					<h3>{entry.title}</h3>
					<p>{entry.description}</p>
				</a>
			))}
		</div>
	</section>

	<section class="notes-preview section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">{homepage.fieldNotes.eyebrow}</p>
				<h2>{homepage.fieldNotes.headline}</h2>
			</div>
			<a class="text-link" href="/notes">Read notes</a>
		</div>
		<div class="note-strip">
			{featuredNotes.map((note) => <blockquote>{note.data.title}</blockquote>)}
		</div>
	</section>

	<section class="outside-section section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">{homepage.outsideWork.eyebrow}</p>
				<h2>{homepage.outsideWork.headline}</h2>
			</div>
			<p>{homepage.outsideWork.body}</p>
		</div>
		<div class="life-grid">
			<figure>
				<img src={profile.images.skydiving.src} alt={profile.images.skydiving.alt} loading="lazy" />
				<figcaption>Certified skydiver</figcaption>
			</figure>
			<figure>
				<img src={profile.images.halfMarathon.src} alt={profile.images.halfMarathon.alt} loading="lazy" />
				<figcaption>First half marathon</figcaption>
			</figure>
		</div>
	</section>

	<section class="certifications-section section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">{homepage.certifications.eyebrow}</p>
				<h2>{homepage.certifications.headline}</h2>
			</div>
		</div>
		<div class="certification-grid">
			{certifications.map((certification) => (
				<article>
					<span class="tag">{certification.issuer}</span>
					<h3>{certification.name}</h3>
					{certification.date && <p>{certification.date}</p>}
				</article>
			))}
		</div>
	</section>

	<section class="speaking-cta section-shell">
		<div>
			<p class="kicker">{homepage.contact.eyebrow}</p>
			<h2>{homepage.contact.headline}</h2>
			<p>{homepage.contact.description}</p>
		</div>
		<a class="button" href="/contact">{homepage.contact.cta}</a>
	</section>
</SiteLayout>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.75fr);
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
		min-height: calc(100vh - 72px);
		padding: 6rem 0 4rem;
	}

	.hero-copy {
		display: grid;
		gap: 1.4rem;
	}

	.hero-subhead {
		max-width: 760px;
		color: var(--graphite);
		font-size: clamp(1.18rem, 2.1vw, 1.55rem);
		line-height: 1.45;
	}

	.hero-support {
		max-width: 700px;
		font-size: 1.05rem;
	}

	.hero-visual {
		min-height: 520px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background:
			linear-gradient(120deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.46)),
			radial-gradient(circle at 78% 18%, rgba(21, 93, 252, 0.14), transparent 16rem);
		box-shadow: var(--shadow);
		overflow: hidden;
		padding: 1.5rem;
	}

	.diagram-shell {
		position: relative;
		height: 100%;
		min-height: 470px;
		border: 1px solid rgba(17, 19, 24, 0.08);
		background-image:
			linear-gradient(rgba(17, 19, 24, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(17, 19, 24, 0.045) 1px, transparent 1px);
		background-size: 42px 42px;
		overflow: hidden;
	}

	.hero-photo {
		position: absolute;
		left: 50%;
		top: 50%;
		width: min(62%, 340px);
		aspect-ratio: 4 / 5;
		border: 1px solid rgba(17, 19, 24, 0.12);
		border-radius: var(--radius);
		box-shadow: 0 24px 70px rgba(17, 19, 24, 0.16);
		object-fit: cover;
		object-position: center 32%;
		transform: translate(-50%, -50%);
		z-index: 1;
	}

	.node {
		position: absolute;
		z-index: 2;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.86);
		box-shadow: 0 14px 40px rgba(17, 19, 24, 0.06);
		color: var(--graphite);
		font-family: var(--mono);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		padding: 0.85rem 1rem;
		text-transform: uppercase;
	}

	.node-primary {
		left: 1rem;
		bottom: 1rem;
		border-color: rgba(21, 93, 252, 0.34);
		background: #f7fbff;
		color: var(--accent);
	}

	.node-evaluate {
		right: 1rem;
		top: 1rem;
	}

	.node-adopt {
		right: 1rem;
		bottom: 1rem;
	}

	.node-operate {
		left: 1rem;
		top: 48%;
	}

	.node-govern {
		left: 1rem;
		top: 1rem;
	}

	.trace {
		position: absolute;
		inset: 18%;
		border: 1px solid rgba(21, 93, 252, 0.22);
		border-radius: 50%;
		transform: rotate(-18deg);
	}

	.trace-b {
		inset: 29% 11%;
		border-color: rgba(17, 19, 24, 0.14);
		transform: rotate(24deg);
	}

	.contour {
		position: absolute;
		border: 1px solid rgba(17, 19, 24, 0.12);
		border-radius: 45% 55% 42% 58%;
		pointer-events: none;
	}

	.contour-a {
		right: -18%;
		bottom: -10%;
		width: 56%;
		height: 42%;
		transform: rotate(-18deg);
	}

	.contour-b {
		right: -8%;
		bottom: 5%;
		width: 36%;
		height: 28%;
		transform: rotate(-8deg);
	}

	.signal {
		position: absolute;
		z-index: 3;
		right: 18%;
		top: 45%;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 14px rgba(21, 93, 252, 0.1);
	}

	.credibility {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		border-block: 1px solid var(--line);
	}

	.credibility span {
		min-height: 92px;
		border-right: 1px solid var(--line);
		color: var(--graphite);
		display: flex;
		align-items: center;
		font-family: var(--mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		padding: 1rem;
		text-transform: uppercase;
	}

	.credibility span:last-child {
		border-right: 0;
	}

	.about-preview,
	.focus-section,
	.writing-preview,
	.notes-preview,
	.outside-section,
	.certifications-section,
	.speaking-cta {
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.about-preview {
		display: grid;
		grid-template-columns: 0.3fr 1fr;
		gap: 3rem;
	}

	.about-preview h2 {
		max-width: 900px;
		margin-bottom: 1.4rem;
	}

	.about-preview p:not(.kicker) {
		max-width: 780px;
		font-size: 1.18rem;
	}

	.focus-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
	}

	.focus-card {
		min-height: 250px;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: 1.4rem;
	}

	.focus-card h3 {
		margin-bottom: 1rem;
	}

	.card-topline {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: center;
	}

	.writing-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.writing-card {
		display: grid;
		min-height: 310px;
		align-content: space-between;
		gap: 1rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.58);
		color: inherit;
		padding: 1.25rem;
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease,
			background 160ms ease;
	}

	.writing-card:hover,
	.certification-grid article:hover {
		background: var(--surface);
		box-shadow: var(--shadow);
		transform: translateY(-2px);
	}

	.section-note {
		max-width: 680px;
		margin: -1rem 0 1.5rem;
		color: var(--muted);
	}

	.note-strip {
		display: grid;
		grid-template-columns: repeat(5, minmax(220px, 1fr));
		gap: 1rem;
		overflow-x: auto;
		padding-bottom: 0.5rem;
	}

	.note-strip blockquote {
		min-height: 190px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.58);
		color: var(--ink);
		font-size: 1.16rem;
		font-weight: 600;
		line-height: 1.35;
		padding: 1rem;
	}

	.speaking-cta {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 2rem;
		align-items: center;
		border-top: 1px solid var(--line);
	}

	.outside-section {
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	.life-grid {
		display: grid;
		grid-template-columns: 0.9fr 1.1fr;
		gap: 1rem;
	}

	.life-grid figure {
		display: grid;
		gap: 0.75rem;
		margin: 0;
	}

	.life-grid img {
		width: 100%;
		aspect-ratio: 4 / 5;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--surface);
		box-shadow: var(--shadow);
		object-fit: cover;
	}

	.life-grid figure:first-child img {
		object-position: center 34%;
	}

	.life-grid figure:nth-child(2) img {
		aspect-ratio: 5 / 4;
		object-position: center 48%;
	}

	.life-grid figcaption {
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.certification-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.certification-grid article {
		display: grid;
		align-content: space-between;
		min-height: 180px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.58);
		padding: 1.25rem;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease,
			background 160ms ease;
	}

	.certification-grid h3 {
		margin-top: 1rem;
	}

	.speaking-cta h2 {
		max-width: 860px;
		margin: 0.6rem 0 1rem;
	}

	.speaking-cta p:not(.kicker) {
		max-width: 760px;
	}

	.text-link {
		color: var(--ink);
		font-weight: 700;
		text-decoration: none;
	}

	.text-link:hover {
		color: var(--accent);
	}

	@media (max-width: 980px) {
		.hero,
		.about-preview,
		.speaking-cta {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
			padding-top: 4rem;
		}

		.hero-visual {
			min-height: 410px;
		}

		.diagram-shell {
			min-height: 360px;
		}

		.hero-photo {
			width: min(58%, 300px);
		}

		.credibility,
		.focus-grid,
		.writing-grid,
		.certification-grid,
		.life-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 640px) {
		.credibility,
		.focus-grid,
		.writing-grid,
		.certification-grid,
		.life-grid {
			grid-template-columns: 1fr;
		}

		.hero-photo {
			width: 64%;
		}

		.credibility span {
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}

		.node {
			font-size: 0.62rem;
			padding: 0.65rem 0.7rem;
		}
	}
</style>
