---
import { getCollection } from 'astro:content';
import SystemFlow from '../components/SystemFlow.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getProfile } from '../lib/siteContent';

const profile = getProfile();
const writing = (await getCollection('writing'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const projects = (await getCollection('projects')).filter((project) => !project.data.draft);
const latestEssay = writing[0];
const featuredProject = projects.find((project) => project.data.title === 'AgentOps Simulator') ?? projects[0];

const careerFlow = [
	{ label: 'Analytics', detail: 'Find the signal.' },
	{ label: 'Cloud', detail: 'Make it scale.' },
	{ label: 'Infrastructure', detail: 'Keep it standing.' },
	{ label: 'Applied AI', detail: 'Now add judgment.' },
];

const siteMap = [
	{
		label: 'Notes',
		title: 'What the demo forgot.',
		description: 'Essays and quick lessons from building AI systems in the real world.',
		href: '/notes',
		link: 'Read the notes',
	},
	{
		label: 'Projects',
		title: 'Proof, with tradeoffs.',
		description: 'Working builds, architecture decisions, GitHub links, and honest constraints.',
		href: '/systems',
		link: 'View projects',
	},
	{
		label: 'About',
		title: 'Human, still included.',
		description: 'The short version of my work, credentials, controlled chaos, and how to reach me.',
		href: '/about',
		link: 'About and contact',
	},
];
---

<SiteLayout
	title="Revanth Pattipati | Applied AI and Agentic Systems"
	description="Revanth Pattipati builds practical AI systems and shares clear notes, projects, and architecture lessons from the work after the demo."
>
	<section class="hero section-shell">
		<div class="hero-copy">
			<p class="kicker">Applied AI • Agentic Systems • Enterprise Execution</p>
			<h1>Agentic AI, minus the theater.</h1>
			<p>
				I build practical AI systems and explain the tricky parts without making anyone feel
				underqualified for their own browser.
			</p>
			<div class="button-row">
				<a class="button" href="/notes">Read the notes</a>
				<a class="button secondary" href="/systems">View projects</a>
			</div>
		</div>
		<figure class="portrait">
			<img src={profile.images.professional.src} alt={profile.images.professional.alt} />
			<figcaption>
				<span>{profile.name}</span>
				<span>{profile.location}</span>
			</figcaption>
		</figure>
	</section>

	<section class="career section-shell" aria-labelledby="career-heading">
		<div class="section-label">
			<p class="kicker">The useful detour</p>
			<h2 id="career-heading">Built from systems thinking.</h2>
		</div>
		<SystemFlow
			steps={careerFlow}
			label="Career path from analytics through cloud and infrastructure to applied AI"
		/>
	</section>

	<section class="site-map section-shell" aria-labelledby="site-map-heading">
		<header>
			<p class="kicker">A quick tour</p>
			<h2 id="site-map-heading">The whole site, without the whole speech.</h2>
		</header>
		<div class="snapshot-grid">
			{siteMap.map((item) => (
				<a href={item.href}>
					<span>{item.label}</span>
					<h3>{item.title}</h3>
					<p>{item.description}</p>
					<strong>{item.link} →</strong>
				</a>
			))}
		</div>
	</section>

	<section class="latest section-shell" aria-labelledby="latest-heading">
		<header>
			<p class="kicker">Currently useful</p>
			<h2 id="latest-heading">Fresh thinking. Working code.</h2>
		</header>
		<div class="latest-grid">
			<a class="latest-card" href={`/writing/${latestEssay.id}/`}>
				<span>Latest essay</span>
				<h3>{latestEssay.data.title}</h3>
				<p>{latestEssay.data.description}</p>
			</a>
			<a class="latest-card project" href={`/systems/${featuredProject.id}/`}>
				<span>Featured project</span>
				<h3>{featuredProject.data.title}</h3>
				<p>{featuredProject.data.description}</p>
			</a>
		</div>
	</section>

	<section class="newsletter-band section-shell" aria-labelledby="newsletter-heading">
		<div>
			<p class="kicker">FutureProofOS</p>
			<h2 id="newsletter-heading">A smarter Sunday scroll.</h2>
			<p>Practical AI notes for staying useful, curious, and ready for what changes next.</p>
		</div>
		<a class="button light" href="/newsletter">Join FutureProofOS</a>
	</section>
</SiteLayout>

<style>
	:global(body.site-body) {
		background: #f5f2eb;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.55fr);
		gap: clamp(3rem, 8vw, 8rem);
		align-items: center;
		min-height: calc(100vh - 72px);
		padding: clamp(4.5rem, 10vw, 8rem) 0;
	}

	.hero-copy {
		display: grid;
		gap: 1.4rem;
	}

	.hero h1 {
		max-width: 900px;
		font-size: clamp(4rem, 9.5vw, 8.4rem);
		letter-spacing: -0.065em;
		line-height: 0.88;
		text-wrap: balance;
	}

	.hero-copy > p:not(.kicker) {
		max-width: 690px;
		color: var(--graphite);
		font-size: clamp(1.08rem, 2vw, 1.35rem);
		line-height: 1.55;
	}

	.portrait {
		margin: 0;
	}

	.portrait img {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 5;
		border: 1px solid var(--line);
		border-radius: 18px;
		box-shadow: 0 30px 80px rgba(17, 19, 24, 0.13);
		object-fit: cover;
		object-position: center 32%;
	}

	.portrait figcaption {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.8rem;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.68rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.career,
	.site-map,
	.latest {
		border-top: 1px solid var(--line);
		padding: clamp(4.5rem, 9vw, 7.5rem) 0;
	}

	.career {
		display: grid;
		grid-template-columns: minmax(220px, 0.38fr) minmax(0, 1fr);
		gap: clamp(2rem, 6vw, 6rem);
		align-items: center;
	}

	.section-label,
	.site-map header,
	.latest header {
		display: grid;
		gap: 0.7rem;
	}

	.section-label h2,
	.site-map h2,
	.latest h2 {
		font-size: clamp(2.4rem, 5vw, 4.8rem);
		letter-spacing: -0.045em;
	}

	.site-map header,
	.latest header {
		max-width: 800px;
		margin-bottom: clamp(2rem, 5vw, 3.5rem);
	}

	.snapshot-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-top: 1px solid var(--ink);
	}

	.snapshot-grid a {
		display: grid;
		min-height: 285px;
		align-content: start;
		border-right: 1px solid var(--line);
		color: inherit;
		padding: clamp(1.25rem, 3vw, 2rem);
		text-decoration: none;
		transition: background 160ms ease;
	}

	.snapshot-grid a:last-child {
		border-right: 0;
	}

	.snapshot-grid a:hover {
		background: rgba(255, 255, 255, 0.58);
	}

	.snapshot-grid span,
	.latest-card > span {
		color: var(--accent);
		font-family: var(--mono);
		font-size: 0.68rem;
		font-weight: 750;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.snapshot-grid h3 {
		margin: 3.5rem 0 0.8rem;
		font-size: clamp(1.55rem, 2.4vw, 2.1rem);
	}

	.snapshot-grid p {
		max-width: 34ch;
	}

	.snapshot-grid strong {
		margin-top: auto;
		padding-top: 2rem;
		font-size: 0.9rem;
	}

	.latest-grid {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 1rem;
	}

	.latest-card {
		display: grid;
		min-height: 330px;
		align-content: end;
		border: 1px solid var(--line);
		border-radius: 18px;
		background:
			linear-gradient(rgba(17, 19, 24, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(17, 19, 24, 0.035) 1px, transparent 1px),
			rgba(255, 255, 255, 0.54);
		background-size: 34px 34px, 34px 34px, auto;
		color: inherit;
		padding: clamp(1.4rem, 4vw, 2.4rem);
		text-decoration: none;
		transition:
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.latest-card.project {
		background:
			linear-gradient(rgba(21, 93, 252, 0.06) 1px, transparent 1px),
			linear-gradient(90deg, rgba(21, 93, 252, 0.06) 1px, transparent 1px),
			#eef3ff;
		background-size: 34px 34px, 34px 34px, auto;
	}

	.latest-card:hover {
		box-shadow: var(--shadow);
		transform: translateY(-2px);
	}

	.latest-card h3 {
		max-width: 760px;
		margin: 1rem 0 0.8rem;
		font-size: clamp(1.8rem, 3.8vw, 3.5rem);
		letter-spacing: -0.04em;
	}

	.latest-card p {
		max-width: 650px;
	}

	.newsletter-band {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 3rem;
		border-radius: 22px;
		background: #a83f31;
		margin-bottom: clamp(3rem, 7vw, 6rem);
		padding: clamp(2rem, 6vw, 4.5rem);
	}

	.newsletter-band > div {
		display: grid;
		max-width: 760px;
		gap: 0.8rem;
	}

	.newsletter-band .kicker,
	.newsletter-band h2,
	.newsletter-band p {
		color: #fff8f2;
	}

	.newsletter-band h2 {
		font-size: clamp(2.5rem, 6vw, 5.5rem);
		letter-spacing: -0.05em;
	}

	.newsletter-band p:not(.kicker) {
		max-width: 620px;
		color: rgba(255, 248, 242, 0.78);
		font-size: 1.05rem;
	}

	.button.light {
		flex-shrink: 0;
		border-color: #fff8f2;
		background: #fff8f2;
		color: #752a20;
	}

	.button.light:hover {
		border-color: #fff;
		background: #fff;
	}

	@media (max-width: 860px) {
		.hero,
		.career,
		.latest-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
		}

		.portrait {
			max-width: 440px;
		}

		.snapshot-grid {
			grid-template-columns: 1fr;
		}

		.snapshot-grid a {
			min-height: 230px;
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}

		.newsletter-band {
			align-items: flex-start;
			flex-direction: column;
		}
	}

	@media (max-width: 520px) {
		.hero h1 {
			font-size: clamp(3.6rem, 18vw, 5.4rem);
		}

		.portrait figcaption {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.25rem;
		}
	}
</style>
