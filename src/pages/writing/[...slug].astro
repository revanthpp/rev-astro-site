---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('writing')).filter((post) => !post.data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<SiteLayout
	title={`${post.data.title} | Revanth Pattipati`}
	description={post.data.metaDescription ?? post.data.description}
>
	<article class="article section-shell">
		<header class="article-header">
			<a class="back-link" href="/writing">Writing</a>
			<div class="article-meta">
				<span class="tag">{post.data.category}</span>
				<span class="meta">
					{post.data.date.toLocaleDateString('en-US', {
						month: 'long',
						day: 'numeric',
						year: 'numeric',
						timeZone: 'UTC',
					})}
				</span>
				<span class="meta">{post.data.readingTime}</span>
			</div>
			<h1>{post.data.title}</h1>
			<p>{post.data.subtitle ?? post.data.description}</p>
			{(post.data.series || post.data.difficulty) && (
				<div class="article-details">
					{post.data.series && <span class="meta">Series: {post.data.series}</span>}
					{post.data.difficulty && <span class="meta">Level: {post.data.difficulty}</span>}
				</div>
			)}
			{post.data.tags.length > 0 && (
				<div class="article-tags" aria-label="Article tags">
					{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
				</div>
			)}
		</header>
		<div class="prose">
			<Content />
		</div>
	</article>
</SiteLayout>

<script>
	const mermaidBlocks = [
		...document.querySelectorAll<HTMLElement>('pre[data-language="mermaid"]'),
	];

	if (mermaidBlocks.length > 0) {
		const { default: mermaid } = await import('mermaid');

		mermaid.initialize({
			startOnLoad: false,
			theme: 'neutral',
			securityLevel: 'strict',
		});

		for (const [index, block] of mermaidBlocks.entries()) {
			const source = block.textContent ?? '';
			const wrapper = document.createElement('div');
			wrapper.className = 'mermaid-diagram';
			wrapper.setAttribute('aria-label', 'Architecture diagram');

			const { svg } = await mermaid.render(`mermaid-${index}`, source);
			wrapper.innerHTML = svg;
			block.replaceWith(wrapper);
		}
	}
</script>

<style>
	.article {
		max-width: 860px;
		padding: 5rem 0 7rem;
	}

	.article-header {
		display: grid;
		gap: 1.2rem;
		margin-bottom: 3rem;
	}

	.article-header h1 {
		font-size: clamp(2.8rem, 7vw, 5.4rem);
	}

	.article-header p {
		color: var(--graphite);
		font-size: 1.2rem;
		line-height: 1.55;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
	}

	.article-details,
	.article-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		align-items: center;
	}

	.back-link {
		width: fit-content;
		color: var(--muted);
		font-weight: 700;
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--accent);
	}

	:global(.mermaid-diagram) {
		overflow-x: auto;
		margin: 2rem 0;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.72);
		padding: 1rem;
	}

	:global(.callout) {
		margin: 2rem 0;
		border-left: 4px solid var(--accent);
		border-radius: 0 var(--radius) var(--radius) 0;
		background: var(--accent-soft);
		padding: 1.15rem 1.25rem;
	}

	:global(.callout h3) {
		margin: 0 0 0.45rem;
		font-size: 1rem;
	}

	:global(.callout p) {
		color: var(--graphite);
	}

	:global(.article-cta) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 2.25rem 0;
	}

	:global(.article-cta a) {
		display: inline-flex;
		min-height: 44px;
		align-items: center;
		border: 1px solid var(--ink);
		border-radius: 999px;
		background: var(--ink);
		color: #fff;
		font-weight: 700;
		padding: 0.7rem 1rem;
		text-decoration: none;
		transition: transform 160ms ease, background 160ms ease;
	}

	:global(.article-cta a:hover) {
		background: var(--graphite);
		transform: translateY(-1px);
	}

	:global(.article-cta a:active) {
		transform: translateY(1px);
	}

	:global(.mermaid-diagram svg) {
		display: block;
		max-width: 100%;
		height: auto;
		margin: 0 auto;
	}
</style>
