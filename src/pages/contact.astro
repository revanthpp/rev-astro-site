---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SOCIAL_LINKS } from '../consts';
import { getProfile } from '../lib/siteContent';

const profile = getProfile();
---

<SiteLayout
	title="Contact | Revanth Pattipati"
	description="Contact Revanth Pattipati for thoughtful conversations about applied AI, agentic systems, enterprise execution, and the part after the demo."
>
	<section class="contact-page section-shell">
		<div class="contact-copy">
			<p class="kicker">Contact</p>
			<h1>Thoughtful conversations about AI systems and enterprise architecture.</h1>
			<p>
				I’m always interested in thoughtful conversations about applied AI, agentic systems,
				enterprise execution, and what happens after the demo.
			</p>
			<p class="location">{profile.location}</p>
		</div>

		<div class="contact-panel">
			<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noreferrer">
				<span>LinkedIn</span>
				<strong>Connect professionally</strong>
			</a>
			<a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">
				<span>GitHub</span>
				<strong>View code and experiments</strong>
			</a>
			<a href={SOCIAL_LINKS.email}>
				<span>Email</span>
				<strong>Start a conversation</strong>
			</a>
		</div>
	</section>
</SiteLayout>

<style>
	.contact-page {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 420px;
		gap: 4rem;
		align-items: start;
		padding: 5rem 0 7rem;
	}

	.contact-copy h1 {
		margin: 0.7rem 0 1.2rem;
	}

	.contact-copy p:not(.kicker) {
		max-width: 700px;
		color: var(--graphite);
		font-size: 1.2rem;
	}

	.contact-copy .location {
		margin-top: 1rem;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.contact-panel {
		display: grid;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.58);
		box-shadow: var(--shadow);
		overflow: hidden;
	}

	.contact-panel a {
		border-bottom: 1px solid var(--line);
		color: inherit;
		padding: 1.2rem;
		text-decoration: none;
	}

	.contact-panel a:last-child {
		border-bottom: 0;
	}

	.contact-panel a:hover {
		background: var(--surface);
	}

	.contact-panel a span {
		display: block;
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.contact-panel a strong {
		display: block;
		margin-top: 0.35rem;
	}

	@media (max-width: 860px) {
		.contact-page {
			grid-template-columns: 1fr;
		}
	}
</style>
