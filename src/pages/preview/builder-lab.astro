---
import { getCollection } from 'astro:content';
import PreviewLayout from '../../layouts/PreviewLayout.astro';
import { SOCIAL_LINKS } from '../../consts';

const projects = (await getCollection('projects')).filter((project) => !project.data.draft);
const posts = (await getCollection('writing'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 3);
---

<PreviewLayout
	title="Builder Lab Preview | Revanth Pattipati"
	description="A project-forward builder homepage direction for Revanth Pattipati."
	concept="builder"
>
	<header class="lab-header">
		<a class="lab-mark" href="/" aria-label="Revanth Pattipati home">RP</a>
		<nav aria-label="Builder Lab navigation">
			<a href="/systems">Builds</a>
			<a href="/notes">Notes</a>
			<a href="/newsletter">FutureProofOS</a>
			<a href="/about">About</a>
			<a href="/contact">Contact</a>
		</nav>
		<a class="github-link" href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">GitHub</a>
	</header>

	<section class="lab-hero">
		<div class="hero-copy">
			<p class="lab-label">Applied AI builder</p>
			<h1>AI that survives reality.</h1>
			<p>
				Agent systems, evaluation, governance, and the infrastructure that keeps useful ideas
				from becoming expensive theater.
			</p>
			<div class="lab-actions">
				<a class="lab-button" href="#builds">View the Builds</a>
				<a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">Open GitHub</a>
			</div>
		</div>
		<div class="hero-image">
			<img src="/images/revanth-professional.jpg" alt="Revanth Pattipati smiling" />
			<p>Analytics-trained. Infrastructure-tested. AI-focused.</p>
		</div>
	</section>

	<section class="build-ledger" id="builds">
		<header>
			<h2>Selected builds</h2>
			<p>Reference designs and prototypes with explicit tradeoffs.</p>
		</header>
		<div class="build-list">
			{featuredProjects.map((project) => (
				<article>
					<div class="build-title">
						<p>{project.data.status}</p>
						<h3>{project.data.title}</h3>
					</div>
					<div class="build-detail">
						<p>{project.data.description}</p>
						<ul aria-label={`${project.data.title} technologies`}>
							{project.data.technologies.slice(0, 4).map((technology) => <li>{technology}</li>)}
						</ul>
					</div>
					<a href={`/systems/${project.id}/`} aria-label={`View ${project.data.title}`}>View build</a>
				</article>
			))}
		</div>
	</section>

	<section class="lab-thinking">
		<div class="thinking-intro">
			<h2>Writing that supports the work.</h2>
			<p>
				Architecture gets clearer when the assumptions, failure modes, and tradeoffs are written
				down.
			</p>
		</div>
		<div class="thinking-grid">
			<a class="lead-note" href={`/writing/${posts[0].id}/`}>
				<span>{posts[0].data.readingTime}</span>
				<h3>{posts[0].data.title}</h3>
				<p>{posts[0].data.description}</p>
			</a>
			<div class="supporting-notes">
				{posts.slice(1, 3).map((post) => (
					<a href={`/writing/${post.id}/`}>
						<span>{post.data.category}</span>
						<h3>{post.data.title}</h3>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="lab-newsletter">
		<div>
			<p class="lab-label">FutureProofOS</p>
			<h2>Follow the build process.</h2>
		</div>
		<p>
			Short Sunday notes on agents, evaluations, workflows, tools, and what the logs are trying
			to tell us.
		</p>
		<a class="lab-button" href="/newsletter">Join FutureProofOS</a>
	</section>

	<section class="lab-about">
		<div class="about-image">
			<img
				src="/images/revanth-skydiving-web.jpg"
				alt="Revanth Pattipati skydiving"
				loading="lazy"
			/>
		</div>
		<div>
			<h2>Systems thinking, with a healthy respect for failure modes.</h2>
			<p>
				I came through analytics, data engineering, cloud, and infrastructure before applied
				AI. Outside work, I collect hobbies that make risk management less theoretical.
			</p>
			<a href="/about">About Rev</a>
		</div>
	</section>

	<footer class="lab-footer">
		<p>Revanth Pattipati</p>
		<a href="/preview/human-signal">Next concept: Human Signal</a>
	</footer>
</PreviewLayout>

<style>
	:global(body.preview-builder) {
		--bg: #0f1216;
		--surface: #161b21;
		--surface-strong: #1d242c;
		--ink: #edf1f4;
		--muted: #9ca7b1;
		--line: #303945;
		--accent: #70a8e8;
		background: var(--bg);
		color: var(--ink);
		font-family: "Helvetica Neue", "IBM Plex Sans", Arial, sans-serif;
	}

	:global(.preview-builder *) {
		box-sizing: border-box;
	}

	:global(.preview-builder a) {
		color: inherit;
	}

	.lab-header {
		position: sticky;
		top: 0;
		z-index: 5;
		display: grid;
		width: min(1280px, calc(100% - 48px));
		min-height: 68px;
		grid-template-columns: auto 1fr auto;
		gap: 2rem;
		align-items: center;
		margin: 0 auto;
		border-bottom: 1px solid var(--line);
		background: rgb(15 18 22 / 0.9);
		backdrop-filter: blur(18px);
	}

	.lab-mark {
		display: grid;
		width: 36px;
		height: 36px;
		place-items: center;
		border: 1px solid var(--accent);
		color: var(--accent) !important;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.78rem;
		font-weight: 800;
		text-decoration: none;
	}

	.lab-header nav {
		display: flex;
		justify-content: center;
		gap: clamp(1rem, 2.4vw, 2rem);
	}

	.lab-header nav a,
	.github-link {
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 700;
		text-decoration: none;
	}

	.lab-header nav a:hover,
	.github-link:hover {
		color: var(--accent);
	}

	.lab-hero,
	.build-ledger,
	.lab-thinking,
	.lab-newsletter,
	.lab-about,
	.lab-footer {
		width: min(1280px, calc(100% - 48px));
		margin: 0 auto;
	}

	.lab-hero {
		display: grid;
		min-height: calc(100dvh - 68px);
		grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.55fr);
		gap: clamp(3rem, 8vw, 8rem);
		align-items: center;
		padding: 4rem 0;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1,
	h2,
	h3 {
		color: var(--ink);
	}

	.lab-label {
		margin-bottom: 1rem;
		color: var(--accent);
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 840px;
		margin-bottom: 1.5rem;
		font-size: clamp(3.6rem, 7.5vw, 7.4rem);
		font-weight: 680;
		letter-spacing: -0.06em;
		line-height: 0.94;
	}

	.hero-copy > p:not(.lab-label) {
		max-width: 650px;
		margin-bottom: 2rem;
		color: var(--muted);
		font-size: clamp(1rem, 1.8vw, 1.25rem);
		line-height: 1.6;
	}

	.lab-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 1.4rem;
		align-items: center;
	}

	.lab-actions > a:not(.lab-button),
	.lab-about a {
		color: var(--accent);
		font-size: 0.8rem;
		font-weight: 800;
		text-underline-offset: 0.25em;
	}

	.lab-button {
		display: inline-flex;
		min-height: 46px;
		align-items: center;
		border: 1px solid var(--accent);
		background: var(--accent);
		color: #0f1216 !important;
		font-size: 0.8rem;
		font-weight: 850;
		padding: 0.7rem 0.95rem;
		text-decoration: none;
		transition:
			background 160ms ease,
			transform 160ms ease;
	}

	.lab-button:hover {
		background: #8cbcf0;
		transform: translateY(-2px);
	}

	.hero-image {
		border: 1px solid var(--line);
		background: var(--surface);
		padding: 0.75rem;
	}

	.hero-image img {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 5;
		filter: grayscale(1) contrast(1.08);
		object-fit: cover;
	}

	.hero-image p {
		margin: 0;
		border-top: 1px solid var(--line);
		color: var(--muted);
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.66rem;
		line-height: 1.5;
		padding: 0.75rem 0.25rem 0.1rem;
	}

	.build-ledger {
		padding: clamp(5rem, 10vw, 9rem) 0;
	}

	.build-ledger > header,
	.thinking-intro {
		max-width: 680px;
		margin-bottom: 3rem;
	}

	.build-ledger h2,
	.thinking-intro h2,
	.lab-newsletter h2,
	.lab-about h2 {
		margin-bottom: 1rem;
		font-size: clamp(2.7rem, 5.5vw, 5rem);
		font-weight: 650;
		letter-spacing: -0.05em;
		line-height: 1;
	}

	.build-ledger > header p,
	.thinking-intro p,
	.lab-newsletter > p,
	.lab-about p {
		color: var(--muted);
		line-height: 1.65;
	}

	.build-list {
		border-top: 1px solid var(--line);
	}

	.build-list article {
		display: grid;
		grid-template-columns: minmax(220px, 0.7fr) minmax(0, 1fr) auto;
		gap: clamp(2rem, 6vw, 6rem);
		align-items: start;
		border-bottom: 1px solid var(--line);
		padding: 2rem 0;
	}

	.build-title > p {
		margin-bottom: 0.7rem;
		color: var(--accent);
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		text-transform: uppercase;
	}

	.build-title h3 {
		font-size: clamp(1.5rem, 2.5vw, 2.2rem);
		letter-spacing: -0.03em;
	}

	.build-detail > p {
		color: var(--muted);
		line-height: 1.6;
	}

	.build-detail ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		margin: 1.2rem 0 0;
		padding: 0;
		list-style: none;
	}

	.build-detail li {
		color: #c5ccd2;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.66rem;
	}

	.build-list article > a {
		color: var(--accent);
		font-size: 0.76rem;
		font-weight: 800;
		white-space: nowrap;
	}

	.lab-thinking {
		background: var(--surface);
		padding: clamp(2rem, 6vw, 5rem);
	}

	.thinking-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(260px, 0.55fr);
		gap: 1px;
		background: var(--line);
	}

	.thinking-grid a {
		background: var(--surface-strong);
		text-decoration: none;
		transition: background 160ms ease;
	}

	.thinking-grid a:hover {
		background: #222b34;
	}

	.lead-note {
		min-height: 420px;
		padding: clamp(1.5rem, 4vw, 3rem);
	}

	.lead-note span,
	.supporting-notes span {
		color: var(--accent);
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		text-transform: uppercase;
	}

	.lead-note h3 {
		max-width: 760px;
		margin: clamp(5rem, 10vw, 9rem) 0 1rem;
		font-size: clamp(2.3rem, 4.5vw, 4rem);
		letter-spacing: -0.045em;
		line-height: 1.05;
	}

	.lead-note p {
		max-width: 640px;
		color: var(--muted);
		line-height: 1.6;
	}

	.supporting-notes {
		display: grid;
		gap: 1px;
		background: var(--line);
	}

	.supporting-notes a {
		display: grid;
		min-height: 200px;
		align-content: space-between;
		padding: 1.5rem;
	}

	.supporting-notes h3 {
		margin: 2rem 0 0;
		font-size: 1.35rem;
		line-height: 1.15;
	}

	.lab-newsletter {
		display: grid;
		grid-template-columns: 0.9fr 0.8fr auto;
		gap: clamp(2rem, 6vw, 6rem);
		align-items: end;
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.lab-newsletter h2 {
		margin-bottom: 0;
	}

	.lab-newsletter > p {
		margin-bottom: 0;
	}

	.lab-about {
		display: grid;
		grid-template-columns: minmax(300px, 0.7fr) minmax(0, 1fr);
		gap: clamp(3rem, 8vw, 8rem);
		align-items: center;
		padding: clamp(5rem, 10vw, 9rem) 0;
	}

	.about-image {
		border: 1px solid var(--line);
		padding: 0.75rem;
	}

	.about-image img {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 3;
		filter: grayscale(1) contrast(1.1);
		object-fit: cover;
	}

	.lab-about p {
		max-width: 670px;
	}

	.lab-about a {
		display: inline-block;
		margin-top: 1.5rem;
	}

	.lab-footer {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		border-top: 1px solid var(--line);
		padding: 2rem 0;
		font-size: 0.76rem;
		font-weight: 700;
	}

	.lab-footer p {
		margin: 0;
		color: var(--muted);
	}

	@media (max-width: 840px) {
		.lab-header {
			grid-template-columns: auto 1fr;
			padding: 0.8rem 0;
		}

		.lab-header nav {
			justify-content: flex-start;
			overflow-x: auto;
			scrollbar-width: none;
		}

		.lab-header nav::-webkit-scrollbar {
			display: none;
		}

		.lab-header nav a {
			white-space: nowrap;
		}

		.github-link {
			display: none;
		}

		.lab-hero,
		.thinking-grid,
		.lab-newsletter,
		.lab-about {
			grid-template-columns: 1fr;
		}

		.lab-hero {
			min-height: auto;
			padding: 4rem 0;
		}

		h1 {
			font-size: clamp(3.2rem, 14vw, 5.5rem);
		}

		.hero-image {
			max-width: 460px;
		}

		.build-list article {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.lab-newsletter {
			align-items: start;
		}

		.lab-newsletter .lab-button {
			width: fit-content;
		}
	}

	@media (max-width: 520px) {
		.lab-header,
		.lab-hero,
		.build-ledger,
		.lab-thinking,
		.lab-newsletter,
		.lab-about,
		.lab-footer {
			width: min(100% - 28px, 1280px);
		}

		.lab-thinking {
			width: 100%;
		}

		.lab-footer {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
