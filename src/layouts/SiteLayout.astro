---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Revanth Pattipati',
  description = 'AI infrastructure and agentic systems architect',
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="site-body">
    <Header />

    <div class="site-shell">
      <main class="site-main">
        <slot />
      </main>
    </div>

    <Footer />
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
  }

  :global(body.site-body) {
    min-height: 100vh;
  }

  .site-shell {
    min-height: calc(100vh - 120px);
  }

  .site-main {
    width: 100%;
  }
</style>
