---
import BaseHead from '../components/BaseHead.astro';

interface Props {
	title: string;
	description: string;
	concept: string;
	noindex?: boolean;
}

const { title, description, concept, noindex = true } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
	</head>
	<body class:list={['preview-body', `preview-${concept}`]}>
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	:global(html),
	:global(body) {
		margin: 0;
		padding: 0;
	}

	:global(body.preview-body) {
		min-height: 100vh;
	}

	main {
		width: 100%;
	}
</style>
