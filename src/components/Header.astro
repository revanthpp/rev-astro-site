---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { getNavigation, getProfile } from '../lib/siteContent';

const profile = getProfile();
const navigation = getNavigation();
---

<header class="site-header">
	<nav class="nav-shell" aria-label="Primary navigation">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
			<span>{profile.name}</span>
			<small>{profile.positioning}</small>
		</a>
		<div class="nav-links">
			{navigation.items.map((item) => <HeaderLink href={item.href}>{item.label}</HeaderLink>)}
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid rgba(17, 19, 24, 0.08);
		background: rgba(247, 246, 242, 0.82);
		backdrop-filter: blur(22px);
	}

	.nav-shell {
		display: flex;
		width: min(1180px, calc(100% - 40px));
		min-height: 72px;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		margin: 0 auto;
	}

	.brand {
		display: grid;
		gap: 0.08rem;
		color: var(--ink);
		text-decoration: none;
	}

	.brand span {
		font-size: 0.95rem;
		font-weight: 720;
		letter-spacing: 0;
	}

	.brand small {
		color: var(--muted);
		font-family: var(--mono);
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.nav-links a {
		border-radius: 999px;
		color: var(--muted);
		font-size: 0.88rem;
		font-weight: 620;
		padding: 0.5rem 0.72rem;
		transition:
			background 160ms ease,
			color 160ms ease;
	}

	.nav-links a:hover,
	.nav-links a.active {
		background: rgba(255, 255, 255, 0.72);
		color: var(--ink);
	}

	@media (max-width: 900px) {
		.nav-shell {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.8rem;
			padding: 0.9rem 0;
		}

		.nav-links {
			width: 100%;
			overflow-x: auto;
			padding-bottom: 0.15rem;
		}

		.nav-links a {
			white-space: nowrap;
		}
	}
</style>
