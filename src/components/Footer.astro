---
import { SOCIAL_LINKS } from '../consts';

const today = new Date();
---

<footer class="site-footer">
	<div class="footer-shell">
		<div class="footer-brand">
			<strong>Revanth Pattipati</strong>
			<span>&copy; {today.getFullYear()}</span>
		</div>
		<nav aria-label="Footer links">
			<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
			<a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">GitHub</a>
			<a href={SOCIAL_LINKS.email}>Email</a>
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--line);
		padding: 2.5rem 0;
	}

	.footer-shell {
		display: flex;
		width: min(1180px, calc(100% - 40px));
		justify-content: space-between;
		gap: 1.5rem;
		align-items: center;
		margin: 0 auto;
	}

	.footer-brand {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		align-items: baseline;
	}

	strong {
		font-size: 0.95rem;
	}

	span {
		color: var(--muted);
		font-size: 0.92rem;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem 1rem;
	}

	a {
		color: var(--ink);
		font-size: 0.92rem;
		font-weight: 650;
		text-decoration: none;
	}

	a:hover {
		color: var(--accent);
	}

	@media (max-width: 760px) {
		.footer-shell {
			align-items: flex-start;
			flex-direction: column;
		}

		nav {
			justify-content: flex-start;
		}
	}
</style>
