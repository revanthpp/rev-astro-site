---
import { SOCIAL_LINKS } from '../consts';
import { getProfile } from '../lib/siteContent';

const today = new Date();
const profile = getProfile();
---

<footer class="site-footer">
	<div class="footer-shell">
		<div>
			<strong>{profile.name}</strong>
			<p>{profile.positioning}</p>
		</div>
		<nav aria-label="Footer links">
			<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
			<a href={SOCIAL_LINKS.github} target="_blank" rel="noreferrer">GitHub</a>
			<a href={SOCIAL_LINKS.email}>Email</a>
		</nav>
		<span>&copy; {today.getFullYear()}</span>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--line);
		padding: 2.5rem 0;
	}

	.footer-shell {
		display: grid;
		width: min(1180px, calc(100% - 40px));
		grid-template-columns: 1.3fr auto auto;
		gap: 2rem;
		align-items: center;
		margin: 0 auto;
	}

	strong {
		display: block;
		margin-bottom: 0.25rem;
	}

	p,
	span {
		color: var(--muted);
		font-size: 0.92rem;
	}

	nav {
		display: flex;
		gap: 1rem;
	}

	a {
		color: var(--ink);
		font-size: 0.92rem;
		font-weight: 650;
		text-decoration: none;
	}

	a:hover {
		color: var(--accent);
	}

	@media (max-width: 760px) {
		.footer-shell {
			grid-template-columns: 1fr;
			align-items: start;
			gap: 1.2rem;
		}
	}
</style>
